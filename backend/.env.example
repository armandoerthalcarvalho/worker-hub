# ============================================================
# Worker Hub — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.
# Set these as Railway environment variables in production.
# ============================================================

# --- AI Provider Keys ---

# Groq API key (normal tier + fallback)
# Get yours at: https://console.groq.com
GROQ_API_KEY=gsk_...

# SambaNova Cloud API key (deep tier — primary)
# Get yours at: https://cloud.sambanova.ai
SAMBANOVA_API_KEY=your-sambanova-api-key-here

# --- Security ---

# Secret token the frontend sends in X-Worker-Token header.
# Generate a strong random string, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
WORKER_TOKEN=change-me-to-a-long-random-secret

# --- CORS ---

# Exact origin of your frontend (no trailing slash).
# Examples:
#   https://myapp.netlify.app
#   https://myuser.github.io
ALLOWED_ORIGIN=https://your-frontend-domain.netlify.app
